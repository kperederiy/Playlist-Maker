<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ToolbarTitleTextAppearance" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/title_text_size</item>
        <item name="android:textColor">?attr/colorSecondaryVariant</item>
        <item name="android:textFontWeight">500</item>
    </style>
    <style name="SettingsTextStyle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">?attr/colorOnSecondary</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/lists_text_size</item>
    </style>
    <style name="RoundedImage2dp">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">2dp</item>
    </style>
    <style name="RoundedImage8dp" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    <style name="TrackInfoLabel">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">@color/gray</item>
        <item name="android:layout_marginTop">17dp</item>
    </style>

    <style name="TrackInfoValue">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">?attr/colorOnSecondary</item>
        <item name="android:layout_marginTop">17dp</item>
    </style>

    <style name="TabLayoutTextStyle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="textAllCaps">false</item>
    </style>
    <style name="BottomNavText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">@font/ys_display_regular</item>
    </style>

</resources>